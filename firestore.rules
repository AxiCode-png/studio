rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AXI SHORTS SECURITY RULES
     * 
     * تم تعديل القواعد للسماح للجميع برؤية الملفات الشخصية (الاسم والصورة) 
     * لضمان ظهور فيديوهات الآخرين في الصفحة الرئيسية بدون أخطاء.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isUploader(uploaderId) {
      return isSignedIn() && request.auth.uid == uploaderId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      // السماح للجميع برؤية بيانات المستخدم لعرضها في الفيديوهات
      allow get: if true;
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);
    }

    match /videos/{videoId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow update: if resource != null && isUploader(resource.data.uploaderId);
      allow delete: if resource != null && isUploader(resource.data.uploaderId);
    }

  }
}