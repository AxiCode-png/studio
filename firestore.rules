rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * قواعد حماية AXI PRO MAX
     * تسمح للجميع برؤية الأسماء والصور الشخصية لضمان ظهور الفيديوهات بشكل صحيح للجميع.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      // السماح للجميع بقرأة الملف الشخصي لعرض الاسم في الفيديوهات
      allow get: if true;
      allow list: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /videos/{videoId} {
      // الفيديوهات عامة للجميع للمشاهدة
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
    }
  }
}