
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information within the AXI Shorts application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "firstName": {
          "type": "string",
          "description": "The user's first name."
        },
        "lastName": {
          "type": "string",
          "description": "The user's last name."
        },
        "age": {
          "type": "number",
          "description": "The user's age."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "joinedAt": {
          "type": "string",
          "description": "ISO timestamp of when the user joined."
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName",
        "age",
        "email"
      ]
    },
    "Video": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Video",
      "type": "object",
      "description": "Represents a short video uploaded by a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Video entity."
        },
        "videoUrl": {
          "type": "string",
          "description": "The URL pointing to the video file.",
          "format": "uri"
        },
        "uploaderId": {
          "type": "string",
          "description": "Reference to the UserProfile who uploaded this video."
        },
        "uploadTimestamp": {
          "type": "object",
          "description": "Server timestamp of upload."
        },
        "title": {
          "type": "string"
        },
        "hashtags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "likesCount": {
          "type": "number"
        }
      },
      "required": [
        "videoUrl",
        "uploaderId",
        "title"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/backend/entities/UserProfile"
      },
      "description": "Stores user profiles."
    },
    "/videos/{videoId}": {
      "schema": {
        "$ref": "#/backend/entities/Video"
      },
      "description": "Stores video metadata."
    }
  }
}
